const { google } = require("googleapis")

async function criarEvento(dados){

 const calendar = google.calendar("v3")

 await calendar.events.insert({
  calendarId: "primary",
  requestBody: {
   summary: dados.servico,
   description: dados.nome,
   start: {
    dateTime: dados.data
   },
   end: {
    dateTime: dados.data
   }
  }
 })

}

module.exports = { criarEvento }